includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon

parameters:
    doctrine:
        objectManagerLoader: tests/object-manager.php

    ignoreErrors:
        - identifier: missingType.generics
        # APCu is enabled on the Upsun runtime (.upsun/config.yaml extensions) but
        # is not loaded in the local/CI CLI, so PHPStan can't resolve its functions.
        -
            message: '#^Function apcu_[a-z]+ not found\.$#'
            paths:
                - src/Controller/TrafficSimulationController.php
                - src/EventSubscriber/AutoRcaSubscriber.php

    level: 6
    paths:
        - bin
        - config
        - public
        - src
        - tests

    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
