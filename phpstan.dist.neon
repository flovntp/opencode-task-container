includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon

parameters:
    doctrine:
        objectManagerLoader: tests/object-manager.php

    ignoreErrors:
        - identifier: missingType.generics

        # The return type of buildIncidentPayload is a complex associative array;
        # adding a full @return annotation would be verbose and doesn't add safety.
        -
            message: '#^Method App\\EventSubscriber\\AutoRcaSubscriber::buildIncidentPayload\(\) return type has no value type specified in iterable type array\.$#'
            path: src/EventSubscriber/AutoRcaSubscriber.php
        -
            message: '#^Method App\\Controller\\Admin\\AutoRcaController::buildIncidentVariables\(\) return type has no value type specified in iterable type array\.$#'
            path: src/Controller/Admin/AutoRcaController.php

    level: 6
    paths:
        - bin
        - config
        - public
        - src
        - tests

    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
