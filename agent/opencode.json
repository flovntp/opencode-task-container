{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "openslimedit@latest",
        "@tarquinen/opencode-dcp@latest",
        "opencode-snip@latest"
    ],
    "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow"
    },
     "mcp": {
        "upsun": {
        "type": "remote",
        "url": "https://mcp.upsun.com/mcp",
        "headers": {
            "upsun-api-token": "${UPSUN_CLI_TOKEN}",
            "enable-write": "true"
        },
        "enabled": true
        }
    }
}
