# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
DATABASE_URL="sqlite:///%kernel.project_dir%/data/database.sqlite"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> upsun/upsun-sdk-php ###
# Upsun API token — override in .env.local or via Upsun project variable (env:UPSUN_API_TOKEN)
UPSUN_API_TOKEN=
# ID of the task container definition in .upsun/config.yaml (e.g. "opencode-rca")
UPSUN_RCA_TASK_ID=opencode-rca
# Injected automatically by Upsun at runtime; set locally for dev/test
PLATFORM_PROJECT=m4kqny2hy3gry
PLATFORM_BRANCH=main
PLATFORM_ENVIRONMENT_TYPE=development
# Set to "true" on production environments only (controls AutoRcaSubscriber)
IS_PRODUCTION=false
###< upsun/upsun-sdk-php ###

###> auto-rca traffic simulation ###
# Shared secret guarding the public load endpoint
# (/admin/auto-rca/simulate-traffic-exception). Empty = endpoint returns 403.
# Set a real value via a sensitive Upsun variable: env:TRAFFIC_SIM_TOKEN
TRAFFIC_SIM_TOKEN=
# Number of concurrent in-flight requests above which the endpoint throws a 500.
# Keep it BELOW the PHP-FPM worker count, otherwise FPM saturates first (502/504).
TRAFFIC_SIM_MAX_CONCURRENCY=3
# Duration (seconds) of the CPU-intensive processing loop.
TRAFFIC_SIM_DURATION=20
###< auto-rca traffic simulation ###

###> github auto-rca app ###
# GitHub App used to open RCA pull requests. The private key is the only
# long-lived secret; set it via a sensitive Upsun variable (base64-encoded PEM):
#   env:GITHUB_APP_PRIVATE_KEY, env:GITHUB_APP_ID, env:GITHUB_APP_INSTALLATION_ID
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# Repository the App is installed on (owner/repo)
GITHUB_REPO=flovntp/opencode-task-container
###< github auto-rca app ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> blackfireio/blackfire-symfony-meta ###
# Get your SERVER credentials at https://blackfire.io/my/settings/credentials
# BLACKFIRE_SERVER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# BLACKFIRE_SERVER_TOKEN=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
###< blackfireio/blackfire-symfony-meta ###
